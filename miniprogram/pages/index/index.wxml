<view class="page">
  <scroll-view scroll-y class="page-scroll" show-scrollbar="{{false}}">
    <view class="hero">
      <view class="hero-main">
        <view class="hero-copy">
          <text class="hero-kicker">净莲阁</text>
          <text class="hero-title">素食 · 文化 · 净心</text>
          <text class="hero-desc">今日菜单、活动与随喜功德，一处查看。</text>
          <view class="hero-ink-line"></view>
        </view>
      </view>
    </view>

    <view wx:if="{{loading || offlineMode}}" class="status-strip {{offlineMode ? 'status-warn' : ''}}">
      <text>{{loading ? '正在同步后端数据' : '后端未连接，当前显示预览数据'}}</text>
      <text wx:if="{{backendError}}" class="status-detail">{{backendError}}</text>
    </view>

    <view class="stats-row">
      <view class="stat-item" wx:for="{{quickStats}}" wx:key="label">
        <text class="stat-value">{{item.value}}</text>
        <text class="stat-label">{{item.label}}</text>
      </view>
    </view>

    <scroll-view scroll-x class="tabs" show-scrollbar="{{false}}">
      <view class="tab-track">
        <view
          wx:for="{{navItems}}"
          wx:key="key"
          class="tab {{activeTab === item.key ? 'tab-active' : ''}}"
          data-key="{{item.key}}"
          bindtap="switchTab"
        >
          {{item.title}}
        </view>
      </view>
    </scroll-view>

    <view wx:if="{{activeTab === 'home'}}" class="section">
      <view class="section-header">
        <text class="section-title">今日推荐</text>
        <text class="section-subtitle">清淡、均衡、当季</text>
      </view>

      <view wx:if="{{featuredMenu}}" class="featured-menu" data-id="{{featuredMenu.id}}" bindtap="openMenuDetail">
        <view class="featured-hero">
          <image wx:if="{{featuredMenu.imageUrl}}" src="{{featuredMenu.imageUrl}}" mode="aspectFill" class="featured-photo"></image>
          <view wx:else class="featured-art menu-art-{{featuredMenu.color}}">
            <text>{{featuredMenu.initial}}</text>
          </view>
          <view class="featured-overlay"></view>
          <text class="featured-title">{{featuredMenu.name}}</text>
        </view>
        <view class="featured-content">
          <text class="featured-desc">{{featuredMenu.desc}}</text>
          <view class="tag-row">
            <text class="tag" wx:for="{{featuredMenu.ingredients}}" wx:key="*this">{{item}}</text>
          </view>
          <view class="featured-bottom">
            <text class="featured-nutrition">{{featuredMenu.nutrition}}</text>
            <button
              class="like-btn {{featuredMenu.liked ? 'liked' : ''}}"
              data-id="{{featuredMenu.id}}"
              catchtap="toggleLike"
            >
              ♥ {{featuredMenu.likeCount}}
            </button>
          </view>
        </view>
      </view>
      <view wx:else class="empty-card">
        <text class="empty-card-title">暂无推荐素食</text>
        <text class="empty-card-desc">后台添加菜单后，这里会显示今日推荐。</text>
      </view>

      <view class="section-header compact">
        <text class="section-title">近期活动</text>
      </view>

      <view wx:if="{{activities.length > 0}}" class="activity-list">
        <view class="activity-item" wx:for="{{activities}}" wx:key="id">
          <view class="activity-date">
            <text>{{item.time}}</text>
          </view>
          <view class="activity-content">
            <text class="activity-title">{{item.title}}</text>
            <text class="activity-place">{{item.place}}</text>
          </view>
        </view>
      </view>
      <view wx:else class="empty-card">
        <text class="empty-card-title">暂无近期活动</text>
        <text class="empty-card-desc">活动发布后，会在首页同步展示。</text>
      </view>
    </view>

    <view wx:if="{{activeTab === 'menu'}}" class="section">
      <view class="search-box">
        <text class="search-icon">⌕</text>
        <input
          class="search-input"
          placeholder="搜索菜名、食材"
          placeholder-class="search-placeholder"
          value="{{keyword}}"
          bindinput="onSearchInput"
        />
        <button wx:if="{{keyword}}" class="clear-btn" bindtap="clearSearch">×</button>
      </view>

      <view wx:if="{{menus.length > 0}}" class="menu-list">
        <view class="menu-card" wx:for="{{menus}}" wx:key="id">
          <view class="menu-card-main" data-id="{{item.id}}" bindtap="openMenuDetail">
            <image wx:if="{{item.imageUrl}}" src="{{item.imageUrl}}" mode="aspectFill" class="menu-photo"></image>
            <view wx:else class="menu-art menu-art-{{item.color}}">
              <text>{{item.initial}}</text>
            </view>
            <view class="menu-info">
              <view class="menu-headline">
                <view class="menu-title-block">
                  <text class="menu-name">{{item.name}}</text>
                  <text class="menu-desc">{{item.desc}}</text>
                </view>
                <button
                  class="like-btn menu-like-btn {{item.liked ? 'liked' : ''}}"
                  data-id="{{item.id}}"
                  catchtap="toggleLike"
                >
                  ♥ {{item.likeCount}}
                </button>
              </view>
            </view>
          </view>
          <view class="menu-card-details">
            <view class="menu-detail-row">
              <text class="menu-detail-label">主要食材</text>
              <view class="tag-row menu-detail-tags">
                <text class="tag" wx:for="{{item.ingredients}}" wx:for-item="ingredient" wx:key="*this">{{ingredient}}</text>
              </view>
            </view>
            <view class="menu-detail-row">
              <text class="menu-detail-label">营养价值</text>
              <view class="nutrition-chip-row">
                <text class="nutrition-summary-item" wx:for="{{item.nutritionItems}}" wx:for-item="nutrition" wx:key="*this">{{nutrition}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>

      <view wx:if="{{menus.length === 0}}" class="empty-state">
        <text class="empty-title">{{keyword ? '没有找到相关素食' : '暂无素食菜单'}}</text>
        <text class="empty-desc">{{keyword ? '换一个菜名或食材试试' : '后台添加菜单后，这里会自动展示'}}</text>
      </view>
    </view>

    <view wx:if="{{activeTab === 'donation'}}" class="section">
      <view class="donation-dev-panel">
        <text class="donation-dev-kicker">功德榜</text>
        <text class="donation-dev-title">小程序捐款功能正在开发</text>
        <text class="donation-dev-copy">目前暂不支持在小程序内提交随喜登记或查看功德榜记录。如需咨询随喜功德相关事宜，请向餐厅前台联系。</text>
      </view>
    </view>

    <view wx:if="{{activeTab === 'about'}}" class="section">
      <view class="about-panel">
        <image class="about-logo" src="../../images/jingliange-logo.jpg" mode="aspectFit"></image>
        <text class="about-title">净莲阁</text>
        <text class="about-copy">{{aboutDescription}}</text>
      </view>

      <view class="info-grid">
        <view class="info-item">
          <text class="info-label">开放时间</text>
          <text class="info-value">11:00 - 13:00</text>
        </view>
        <view class="info-item">
          <text class="info-label">地址</text>
          <text class="info-value">温州市瓯海区茶山大学城高科路 103 号</text>
        </view>
        <view class="info-item">
          <text class="info-label">联系电话</text>
          <text class="info-value">13868683322</text>
        </view>
      </view>

      <button class="admin-entry" bindtap="openAdmin">内容管理</button>
    </view>

    <view class="bottom-space"></view>
  </scroll-view>

  <view wx:if="{{selectedMenu}}" class="detail-mask" bindtap="closeMenuDetail">
    <view
      class="detail-sheet"
      style="transform: translateY({{detailSheetTranslateY}}px); transition: {{detailSheetTransition}};"
      catchtap="noop"
    >
      <view
        class="sheet-drag-zone"
        catchtouchstart="onSheetDragStart"
        catchtouchmove="onSheetDragMove"
        catchtouchend="onSheetDragEnd"
        catchtouchcancel="onSheetDragEnd"
      >
        <view class="sheet-handle"></view>
      </view>
      <image wx:if="{{selectedMenu.imageUrl}}" src="{{selectedMenu.imageUrl}}" mode="aspectFill" class="sheet-photo"></image>
      <view wx:else class="menu-art menu-art-{{selectedMenu.color}} sheet-art">
        <text>{{selectedMenu.initial}}</text>
      </view>
      <text class="sheet-title">{{selectedMenu.name}}</text>
      <text class="sheet-desc">{{selectedMenu.desc}}</text>
      <view class="sheet-meta">
        <text>{{selectedMenu.likeCount}} 人喜欢</text>
      </view>
      <view class="detail-group">
        <text class="detail-label">主要食材</text>
        <view class="tag-row detail-tags">
          <text class="tag" wx:for="{{selectedMenu.ingredients}}" wx:for-item="ingredient" wx:key="*this">{{ingredient}}</text>
        </view>
      </view>
      <view class="detail-group">
        <text class="detail-label">营养价值表</text>
        <text class="nutrition-note">营养信息仅供参考，不作为健康建议；每份为 100g/100ml。</text>
        <view class="nutrition-list">
          <text class="nutrition-item" wx:for="{{selectedMenu.nutritionItems}}" wx:for-item="nutrition" wx:key="*this">{{nutrition}}</text>
        </view>
      </view>
      <view class="comments-panel">
        <view class="comments-header">
          <text class="comments-title">评论</text>
          <text class="comments-count">{{menuComments.length}}</text>
        </view>
        <view wx:if="{{detailLoading}}" class="comment-empty">正在加载评论</view>
        <view wx:elif="{{menuComments.length === 0}}" class="comment-empty">暂无评论</view>
        <scroll-view wx:else class="comment-list" scroll-y show-scrollbar="{{false}}">
          <view class="comment-item" wx:for="{{menuComments}}" wx:key="id">
            <image wx:if="{{item.avatarUrl}}" class="comment-avatar-img" src="{{item.avatarUrl}}" mode="aspectFill"></image>
            <view wx:else class="comment-avatar">{{item.avatar}}</view>
            <view class="comment-body">
              <view class="comment-topline">
                <text class="comment-user">{{item.userName}}</text>
                <view class="comment-side">
                  <text class="comment-date">{{item.date}}</text>
                  <button wx:if="{{item.isMine}}" class="comment-delete" data-id="{{item.id}}" catchtap="deleteOwnComment">×</button>
                </view>
              </view>
              <text class="comment-text">{{item.comment}}</text>
              <button class="comment-like {{item.liked ? 'comment-like-active' : ''}}" data-id="{{item.id}}" catchtap="toggleCommentLike">
                <text>♥</text>
                <text>{{item.likeCount}}</text>
              </button>
            </view>
          </view>
        </scroll-view>
        <view class="comment-form">
          <input
            class="comment-input"
            placeholder="写下你的感受"
            placeholder-class="form-placeholder"
            value="{{menuCommentText}}"
            bindinput="onMenuCommentInput"
          />
          <button class="comment-submit" bindtap="submitMenuComment">发送</button>
        </view>
      </view>
      <button class="primary-btn sheet-btn" bindtap="closeMenuDetail">完成</button>
    </view>
  </view>
</view>
