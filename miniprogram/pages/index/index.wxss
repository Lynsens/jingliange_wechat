.page {
  min-height: 100vh;
  background: #fbecdf;
  color: #17120f;
}

.page-scroll {
  height: 100vh;
  box-sizing: border-box;
  padding: 108rpx 28rpx 0;
}

.hero {
  position: relative;
  overflow: hidden;
  min-height: 0;
  border-radius: 16rpx;
  border: 1rpx solid rgba(23, 18, 15, 0.1);
  background: #fffaf6;
  color: #17120f;
  padding: 24rpx 26rpx;
}

.hero-main {
  display: block;
}

.hero-kicker,
.hero-title {
  display: block;
}

.hero-kicker {
  color: #7c4a27;
  font-family: "STKaiti", "Kaiti SC", "KaiTi", "Songti SC", serif;
  font-size: 30rpx;
  font-weight: 500;
  line-height: 40rpx;
}

.hero-title {
  margin-top: 10rpx;
  color: #17120f;
  font-family: "STKaiti", "Kaiti SC", "KaiTi", "Songti SC", serif;
  font-size: 46rpx;
  font-weight: 600;
  line-height: 56rpx;
}

.hero-desc {
  display: block;
  margin-top: 8rpx;
  color: #6f5545;
  font-size: 24rpx;
  line-height: 34rpx;
}

.hero-ink-line {
  width: 96rpx;
  height: 3rpx;
  margin-top: 14rpx;
  background: #17120f;
  border-radius: 999rpx;
}

.stats-row {
  display: flex;
  gap: 16rpx;
  margin-top: 14rpx;
}

.status-strip {
  margin-top: 18rpx;
  border-radius: 12rpx;
  background: #fff7f0;
  color: #7c4a27;
  font-size: 24rpx;
  line-height: 36rpx;
  padding: 14rpx 20rpx;
}

.status-warn {
  background: #fff3e8;
  color: #8e562f;
}

.status-detail {
  display: block;
  margin-top: 6rpx;
  font-size: 21rpx;
  line-height: 30rpx;
  word-break: break-all;
}

.stat-item {
  flex: 1;
  min-height: 92rpx;
  border: 1rpx solid rgba(23, 18, 15, 0.1);
  border-radius: 14rpx;
  background: #fffaf6;
  box-sizing: border-box;
  padding: 14rpx 18rpx;
}

.stat-value,
.stat-label {
  display: block;
}

.stat-value {
  color: #ad693e;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 38rpx;
}

.stat-value-text {
  font-family: "STKaiti", "Kaiti SC", "KaiTi", "Songti SC", serif;
  font-size: 29rpx;
  font-weight: 600;
  letter-spacing: 0;
}

.stat-label {
  margin-top: 4rpx;
  color: #7b6253;
  font-size: 22rpx;
}

.tabs {
  margin: 20rpx 0 0;
  white-space: nowrap;
}

.tab-track {
  display: flex;
  width: 100%;
  gap: 14rpx;
  box-sizing: border-box;
}

.tab {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  border: 1rpx solid rgba(23, 18, 15, 0.1);
  border-radius: 999rpx;
  background: #fffaf6;
  color: #6f5545;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1;
  text-align: center;
}

.tab-active {
  border-color: #ad693e;
  background: #ad693e;
  color: #fff;
  font-weight: 700;
}

.section {
  margin-top: 20rpx;
}

.section-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.section-header.compact {
  margin-top: 20rpx;
}

.section-title {
  color: #17120f;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 40rpx;
}

.section-subtitle {
  color: #7b6253;
  font-size: 24rpx;
}

.featured-menu,
.combo-card,
.menu-card,
.donation-panel,
.form-panel,
.about-panel,
.info-item,
.leader-item,
.activity-item,
.empty-card {
  border: 1rpx solid rgba(23, 18, 15, 0.1);
  border-radius: 14rpx;
  background: #fffaf6;
  box-shadow: none;
}

.featured-menu {
  display: flex;
  min-height: 188rpx;
  padding: 0;
  overflow: hidden;
}

.combo-card {
  padding: 24rpx;
}

.combo-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.combo-title-block {
  min-width: 0;
  flex: 1;
}

.combo-title,
.combo-desc,
.combo-menu-name,
.combo-menu-desc {
  display: block;
}

.combo-title {
  color: #17120f;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 42rpx;
}

.combo-desc {
  margin-top: 6rpx;
  color: #6f5545;
  font-size: 24rpx;
  line-height: 34rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recommendation-flow {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 18rpx;
}

.recommendation-slot {
  display: flex;
  min-width: 0;
  gap: 14rpx;
  align-items: center;
  border-radius: 12rpx;
  background: #fff7f0;
  padding: 16rpx;
}

.recommendation-slot-empty {
  opacity: 0.72;
}

.recommendation-index {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  border-radius: 999rpx;
  background: #ad693e;
  color: #fff;
  font-size: 21rpx;
  font-weight: 800;
}

.recommendation-copy {
  min-width: 0;
  flex: 1;
}

.combo-photo,
.combo-art {
  flex: 0 0 auto;
  width: 74rpx;
  height: 74rpx;
  border-radius: 10rpx;
  background: #f8c9a4;
}

.combo-art {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #4b2717;
  font-family: "STKaiti", "Kaiti SC", "KaiTi", "Songti SC", serif;
  font-size: 24rpx;
  font-weight: 800;
}

.combo-menu-name {
  color: #17120f;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 34rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.combo-menu-desc {
  margin-top: 4rpx;
  color: #7b6253;
  font-size: 22rpx;
  line-height: 30rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.featured-hero {
  flex: 0 0 214rpx;
  position: relative;
  min-height: 188rpx;
  overflow: hidden;
  background: #f5dcc8;
}

.featured-photo,
.featured-art {
  display: block;
  width: 100%;
  height: 188rpx;
}

.featured-art {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 66rpx;
  font-weight: 800;
}

.featured-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(23, 18, 15, 0.08), rgba(23, 18, 15, 0.44));
}

.featured-title {
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  bottom: 18rpx;
  display: block;
  color: #fff;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 38rpx;
  text-shadow: 0 4rpx 12rpx rgba(23, 18, 15, 0.35);
}

.menu-art {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 132rpx;
  height: 132rpx;
  border-radius: 14rpx;
  background: #f8c9a4;
  color: #4b2717;
  font-size: 44rpx;
  font-weight: 800;
  font-family: "STKaiti", "Kaiti SC", "KaiTi", "Songti SC", serif;
}

.menu-photo {
  flex: 0 0 auto;
  width: 148rpx;
  height: 148rpx;
  border-radius: 14rpx;
  background: #f5dcc8;
}

.logo-default-photo {
  background: #f8c9a4;
}

.menu-art-green {
  background: #f8c9a4;
}

.menu-art-pink {
  background: #f5d0b2;
}

.menu-art-gold {
  background: #f2c096;
}

.featured-content,
.menu-info {
  min-width: 0;
  flex: 1;
}

.menu-name {
  display: block;
  color: #17120f;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 38rpx;
}

.featured-desc,
.menu-desc,
.about-copy {
  display: block;
  margin-top: 8rpx;
  color: #6f5545;
  font-size: 25rpx;
  line-height: 36rpx;
}

.featured-desc {
  margin-top: 0;
  font-size: 24rpx;
  line-height: 34rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}

.featured-content {
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
  padding: 18rpx 20rpx;
}

.featured-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 12rpx;
}

.featured-nutrition {
  min-width: 0;
  flex: 1;
  color: #ad693e;
  font-size: 23rpx;
  font-weight: 500;
  line-height: 30rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 10rpx;
}

.tag {
  min-height: 38rpx;
  border-radius: 999rpx;
  background: #f8dfca;
  color: #7c4a27;
  font-size: 21rpx;
  line-height: 38rpx;
  padding: 0 16rpx;
}

.featured-content .tag-row {
  flex-wrap: nowrap;
  gap: 8rpx;
  margin-top: 8rpx;
  overflow: hidden;
}

.featured-content .tag {
  max-width: 132rpx;
  min-height: 34rpx;
  font-size: 20rpx;
  line-height: 34rpx;
  overflow: hidden;
  padding: 0 14rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.home-section .activity-list {
  gap: 10rpx;
}

.home-section .activity-item {
  align-items: flex-start;
  gap: 16rpx;
  padding: 16rpx 18rpx;
}

.home-section .activity-date {
  width: 132rpx;
  font-size: 23rpx;
  line-height: 34rpx;
}

.home-section .activity-title {
  font-size: 27rpx;
  line-height: 36rpx;
}

.home-section .activity-place {
  margin-top: 2rpx;
  font-size: 23rpx;
  line-height: 32rpx;
}

.activity-list,
.menu-list,
.leaderboard,
.info-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.activity-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 22rpx;
}

.activity-date {
  width: 150rpx;
  color: #ad693e;
  font-size: 24rpx;
  font-weight: 700;
}

.activity-content {
  flex: 1;
}

.activity-title,
.activity-place {
  display: block;
}

.activity-title {
  color: #17120f;
  font-size: 29rpx;
  font-weight: 700;
}

.activity-place {
  margin-top: 6rpx;
  color: #7b6253;
  font-size: 24rpx;
}

.search-box {
  display: flex;
  align-items: center;
  height: 88rpx;
  border: 1rpx solid rgba(23, 18, 15, 0.1);
  border-radius: 14rpx;
  background: #fffaf6;
  padding: 0 20rpx;
}

.search-icon {
  width: 48rpx;
  color: #8b6a56;
  font-size: 34rpx;
  line-height: 88rpx;
}

.search-input {
  flex: 1;
  height: 88rpx;
  color: #17120f;
  font-size: 28rpx;
}

.search-placeholder,
.form-placeholder,
.placeholder {
  color: #a4836e;
}

.clear-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  box-sizing: border-box;
  border-radius: 50%;
  background: #f8dfca;
  color: #7c4a27;
  font-size: 34rpx;
  line-height: 1;
  padding: 0;
}

.menu-filter-scroll {
  margin: 14rpx -28rpx 0;
  white-space: nowrap;
}

.menu-filter-track {
  display: inline-flex;
  gap: 12rpx;
  padding: 0 28rpx;
}

.menu-filter-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 104rpx;
  height: 54rpx;
  box-sizing: border-box;
  border: 1rpx solid rgba(23, 18, 15, 0.1);
  border-radius: 999rpx;
  background: #fffaf6;
  color: #6f5545;
  font-size: 23rpx;
  font-weight: 700;
  padding: 0 22rpx;
}

.menu-filter-chip-active {
  border-color: #ad693e;
  background: #ad693e;
  color: #fff;
}

.menu-list {
  margin-top: 18rpx;
}

.menu-card {
  padding: 18rpx 24rpx;
}

.menu-card-main {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.menu-info,
.menu-title-block {
  min-width: 0;
  flex: 1;
}

.menu-headline {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.leader-topline {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.menu-card-details {
  margin-top: 12rpx;
  border-top: 1rpx solid rgba(23, 18, 15, 0.08);
  padding-top: 10rpx;
}

.menu-detail-row {
  display: grid;
  grid-template-columns: 118rpx minmax(0, 1fr);
  gap: 12rpx;
  align-items: start;
}

.menu-detail-row + .menu-detail-row {
  margin-top: 6rpx;
}

.menu-detail-label {
  display: block;
  color: #7b6253;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 38rpx;
}

.menu-detail-tags {
  margin-top: 0;
  gap: 8rpx;
}

.menu-detail-tags .tag {
  min-height: 34rpx;
  font-size: 20rpx;
  line-height: 34rpx;
  padding: 0 14rpx;
}

.nutrition-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  min-width: 0;
}

.nutrition-summary-item {
  display: inline-flex;
  align-items: center;
  min-height: 34rpx;
  max-width: 190rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  background: #fff0df;
  color: #ad693e;
  font-size: 20rpx;
  line-height: 1;
  padding: 0 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.detail-label {
  display: block;
  color: #7b6253;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 32rpx;
}

.compact-label {
  margin-top: 16rpx;
}

.like-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 148rpx;
  width: 148rpx;
  min-width: 148rpx;
  max-width: 148rpx;
  height: 58rpx;
  box-sizing: border-box;
  margin: 0;
  border-radius: 999rpx;
  background: #fff1e8;
  color: #8b6a57;
  font-size: 25rpx;
  font-weight: 800;
  line-height: 1;
  padding: 0;
}

.primary-btn,
.comment-submit,
.like-btn,
.clear-btn {
  transition: opacity 0.15s ease;
}

.like-btn.liked {
  background: #ad693e;
  color: #fffaf6;
  font-weight: 800;
}

.menu-like-btn {
  flex-basis: 112rpx;
  width: 112rpx;
  min-width: 112rpx;
  max-width: 112rpx;
  height: 48rpx;
  font-size: 22rpx;
}

.empty-state {
  padding: 80rpx 30rpx;
  text-align: center;
}

.empty-card {
  padding: 34rpx 28rpx;
  text-align: center;
}

.empty-title,
.empty-desc,
.empty-card-title,
.empty-card-desc {
  display: block;
}

.empty-title,
.empty-card-title {
  color: #17120f;
  font-size: 30rpx;
  font-weight: 700;
}

.empty-desc,
.empty-card-desc {
  margin-top: 10rpx;
  color: #7b6253;
  font-size: 25rpx;
  line-height: 36rpx;
}

.donation-panel {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: #fffaf6;
}

.panel-label {
  display: block;
  color: #7b6253;
  font-size: 24rpx;
}

.donation-total {
  display: block;
  margin-top: 8rpx;
  color: #ad693e;
  font-size: 50rpx;
  font-weight: 800;
  line-height: 60rpx;
}

.count-pill {
  border-radius: 999rpx;
  background: #17120f;
  color: #fff;
  font-size: 24rpx;
  padding: 14rpx 20rpx;
}

.donation-dev-panel {
  border: 1rpx solid rgba(23, 18, 15, 0.1);
  border-radius: 14rpx;
  background: #fffaf6;
  padding: 36rpx 30rpx;
}

.suggestion-panel {
  border: 1rpx solid rgba(23, 18, 15, 0.1);
  border-radius: 14rpx;
  background: #fffaf6;
  padding: 32rpx 30rpx;
}

.suggestion-kicker,
.suggestion-title,
.suggestion-copy {
  display: block;
}

.suggestion-kicker {
  color: #ad693e;
  font-family: "STKaiti", "Kaiti SC", "KaiTi", "Songti SC", serif;
  font-size: 28rpx;
  line-height: 38rpx;
}

.suggestion-title {
  margin-top: 12rpx;
  color: #17120f;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 48rpx;
}

.suggestion-copy {
  margin-top: 14rpx;
  color: #6f5545;
  font-size: 25rpx;
  line-height: 40rpx;
}

.suggestion-textarea,
.suggestion-field {
  width: 100%;
  box-sizing: border-box;
  border-radius: 12rpx;
  background: #fff7f0;
  color: #17120f;
  font-size: 27rpx;
  margin-top: 20rpx;
  padding: 0 22rpx;
}

.suggestion-textarea {
  height: 230rpx;
  line-height: 40rpx;
  padding-top: 20rpx;
}

.suggestion-field {
  height: 82rpx;
}

.suggestion-submit {
  margin-top: 20rpx;
}

.donation-dev-kicker,
.donation-dev-title,
.donation-dev-copy {
  display: block;
}

.donation-dev-kicker {
  color: #ad693e;
  font-family: "STKaiti", "Kaiti SC", "KaiTi", "Songti SC", serif;
  font-size: 28rpx;
  line-height: 38rpx;
}

.donation-dev-title {
  margin-top: 12rpx;
  color: #17120f;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 48rpx;
}

.donation-dev-copy {
  margin-top: 16rpx;
  color: #6f5545;
  font-size: 26rpx;
  line-height: 42rpx;
}

.form-panel {
  margin-top: 18rpx;
  padding: 24rpx;
}

.form-title {
  display: block;
  color: #17120f;
  font-size: 32rpx;
  font-weight: 800;
  margin-bottom: 18rpx;
}

.form-input,
.form-textarea {
  width: 100%;
  box-sizing: border-box;
  border-radius: 12rpx;
  background: #fff7f0;
  color: #17120f;
  font-size: 27rpx;
  padding: 0 20rpx;
}

.form-input {
  height: 82rpx;
}

.form-input.stacked {
  margin-top: 16rpx;
}

.form-textarea {
  height: 150rpx;
  margin-top: 16rpx;
  padding-top: 20rpx;
}

.primary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 82rpx;
  box-sizing: border-box;
  border-radius: 12rpx;
  background: #ad693e;
  color: #fff;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1;
  margin-top: 18rpx;
  padding: 0;
}

.leaderboard {
  margin-top: 18rpx;
}

.leader-item {
  display: flex;
  gap: 18rpx;
  padding: 22rpx;
}

.rank {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f8dfca;
  color: #7c4a27;
  font-size: 25rpx;
  font-weight: 800;
}

.leader-content {
  flex: 1;
  min-width: 0;
}

.donor-name {
  color: #17120f;
  font-size: 28rpx;
  font-weight: 800;
}

.donor-amount {
  color: #ad693e;
  font-size: 28rpx;
  font-weight: 800;
}

.donor-message,
.donor-date {
  display: block;
  margin-top: 6rpx;
  color: #6f5545;
  font-size: 24rpx;
}

.donor-date {
  color: #a4836e;
}

.about-panel {
  padding: 30rpx;
}

.about-logo {
  display: block;
  width: 260rpx;
  height: 260rpx;
  margin: 0 auto 26rpx;
  border-radius: 12rpx;
}

.about-title {
  display: block;
  color: #17120f;
  font-family: "STKaiti", "Kaiti SC", "KaiTi", "Songti SC", serif;
  font-size: 42rpx;
  font-weight: 600;
  line-height: 54rpx;
}

.info-grid {
  margin-top: 18rpx;
}

.info-item {
  padding: 24rpx;
}

.info-label,
.info-value {
  display: block;
}

.info-label {
  color: #7b6253;
  font-size: 24rpx;
}

.info-value {
  margin-top: 8rpx;
  color: #17120f;
  font-size: 29rpx;
  font-weight: 600;
}

.admin-entry {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 82rpx;
  box-sizing: border-box;
  margin-top: 18rpx;
  border-radius: 12rpx;
  background: #ad693e;
  color: #fff;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1;
  padding: 0;
}

.detail-mask {
  position: fixed;
  z-index: 40;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: flex-end;
  background: rgba(18, 29, 24, 0.42);
}

.detail-sheet {
  width: 100%;
  max-height: 86vh;
  border-radius: 24rpx 24rpx 0 0;
  background: #fffaf6;
  box-sizing: border-box;
  padding: 18rpx 32rpx 42rpx;
  overflow-y: auto;
  will-change: transform;
}

.sheet-drag-zone {
  height: 112rpx;
  margin: -18rpx -32rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sheet-handle {
  width: 84rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #e2b995;
  margin: 0 auto;
}

.sheet-art {
  width: 156rpx;
  height: 156rpx;
  margin-bottom: 24rpx;
}

.sheet-photo {
  display: block;
  width: 156rpx;
  height: 156rpx;
  border-radius: 14rpx;
  background: #f5dcc8;
  margin-bottom: 24rpx;
}

.sheet-title,
.sheet-desc {
  display: block;
}

.sheet-title {
  color: #17120f;
  font-size: 40rpx;
  font-weight: 800;
}

.sheet-desc {
  margin-top: 12rpx;
  color: #6f5545;
  font-size: 28rpx;
  line-height: 44rpx;
}

.sheet-meta {
  display: flex;
  justify-content: flex-end;
  margin-top: 22rpx;
  color: #ad693e;
  font-size: 25rpx;
}

.detail-group {
  margin-top: 24rpx;
}

.detail-tags {
  margin-top: 12rpx;
}

.nutrition-note {
  display: block;
  margin-top: 8rpx;
  color: #a4836e;
  font-size: 22rpx;
  line-height: 32rpx;
}

.nutrition-list {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.nutrition-item {
  display: block;
  min-height: 42rpx;
  border-radius: 999rpx;
  background: #f8dfca;
  color: #7c4a27;
  font-size: 22rpx;
  line-height: 42rpx;
  padding: 0 18rpx;
}

.comments-panel {
  margin-top: 28rpx;
  border-top: 1rpx solid rgba(23, 18, 15, 0.1);
  padding-top: 24rpx;
}

.comments-header,
.comment-topline,
.comment-form {
  display: flex;
  align-items: center;
}

.comments-header {
  justify-content: space-between;
}

.comments-title {
  color: #17120f;
  font-size: 30rpx;
  font-weight: 800;
}

.comments-count {
  min-width: 44rpx;
  height: 44rpx;
  border-radius: 999rpx;
  background: #f8dfca;
  color: #7c4a27;
  font-size: 22rpx;
  line-height: 44rpx;
  text-align: center;
  padding: 0 12rpx;
}

.comment-empty {
  margin-top: 20rpx;
  border-radius: 12rpx;
  background: #fff7f0;
  color: #7b6253;
  font-size: 25rpx;
  line-height: 72rpx;
  text-align: center;
}

.comment-list {
  margin-top: 20rpx;
  max-height: 354rpx;
  overflow: hidden;
}

.comment-item {
  display: flex;
  gap: 16rpx;
}

.comment-item + .comment-item {
  margin-top: 18rpx;
}

.comment-avatar {
  flex: 0 0 auto;
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  background: #17120f;
  color: #fffaf6;
  font-size: 24rpx;
  font-weight: 700;
  font-family: "STKaiti", "Kaiti SC", "KaiTi", "Songti SC", serif;
  line-height: 54rpx;
  text-align: center;
}

.comment-avatar-img {
  flex: 0 0 auto;
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  background: #f8dfca;
}

.comment-body {
  min-width: 0;
  flex: 1;
  border-radius: 12rpx;
  background: #fff7f0;
  padding: 16rpx 18rpx;
}

.comment-topline {
  justify-content: space-between;
  gap: 16rpx;
}

.comment-user {
  color: #17120f;
  font-size: 24rpx;
  font-weight: 700;
}

.comment-date {
  color: #a4836e;
  font-size: 21rpx;
}

.comment-text {
  display: block;
  margin-top: 8rpx;
  color: #6f5545;
  font-size: 25rpx;
  line-height: 36rpx;
}

.comment-delete {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 42rpx;
  min-width: 72rpx;
  margin-top: 12rpx;
  border-radius: 999rpx;
  background: #f2d0c8;
  color: #a04438;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 1;
  padding: 0 16rpx;
}

.comment-form {
  gap: 14rpx;
  margin-top: 22rpx;
}

.comment-input {
  flex: 1;
  height: 72rpx;
  border-radius: 12rpx;
  background: #fff7f0;
  color: #17120f;
  font-size: 26rpx;
  padding: 0 20rpx;
}

.comment-submit {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  width: 116rpx;
  height: 72rpx;
  box-sizing: border-box;
  border-radius: 12rpx;
  background: #ad693e;
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1;
  padding: 0;
}

.sheet-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 82rpx;
  box-sizing: border-box;
  margin-top: 28rpx;
  border-radius: 12rpx;
  line-height: 1;
  padding: 0;
}

.bottom-space {
  height: 52rpx;
}

button {
  border: 0;
}

button::after {
  border: 0;
}
