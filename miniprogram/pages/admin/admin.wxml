<view class="admin-page">
  <view class="admin-hero">
    <text class="admin-kicker">净莲阁</text>
    <text class="admin-desc">{{adminAuthed ? '管理素食菜单、今日推荐、近期活动、用户评论与建议箱。' : '请输入管理员账号和密码后继续。'}}</text>
  </view>

  <view wx:if="{{!adminAuthed}}" class="panel login-panel">
    <text class="panel-title">管理员登录</text>
    <input
      class="field"
      placeholder="管理员账号"
      placeholder-class="placeholder"
      value="{{adminUsername}}"
      bindinput="onAdminUsernameInput"
    />
    <input
      class="field"
      password
      placeholder="管理员密码"
      placeholder-class="placeholder"
      value="{{adminPassword}}"
      bindinput="onAdminPasswordInput"
    />
    <button class="primary-btn" bindtap="loginAdmin">登录</button>
    <text class="login-note">登录后可管理素食菜单。</text>
  </view>

  <block wx:else>
  <view class="admin-tabs">
    <view class="admin-tab {{adminSection === 'menu' ? 'admin-tab-active' : ''}}" data-section="menu" bindtap="switchAdminSection">菜单管理</view>
    <view class="admin-tab {{adminSection === 'combo' ? 'admin-tab-active' : ''}}" data-section="combo" bindtap="switchAdminSection">推荐管理</view>
    <view class="admin-tab {{adminSection === 'activity' ? 'admin-tab-active' : ''}}" data-section="activity" bindtap="switchAdminSection">活动管理</view>
    <view class="admin-tab {{adminSection === 'comment' ? 'admin-tab-active' : ''}}" data-section="comment" bindtap="switchAdminSection">评论管理</view>
    <view class="admin-tab {{adminSection === 'suggestion' ? 'admin-tab-active' : ''}}" data-section="suggestion" bindtap="switchAdminSection">建议管理</view>
  </view>

  <view wx:if="{{adminSection === 'menu' && !showEditor}}" class="panel">
    <view class="panel-header menu-panel-header">
      <text class="panel-title">菜单列表</text>
      <view class="panel-actions">
        <button class="ghost-btn" loading="{{loading}}" bindtap="loadMenus">刷新</button>
        <button class="compact-primary-btn" bindtap="startCreateMenu">新增菜品</button>
      </view>
    </view>

    <view class="admin-search">
      <text class="admin-search-icon">⌕</text>
      <input
        class="admin-search-input"
        placeholder="搜索菜名、介绍或 ID"
        placeholder-class="placeholder"
        value="{{menuKeyword}}"
        bindinput="onMenuKeywordInput"
      />
      <view wx:if="{{menuKeyword}}" class="admin-clear-btn" bindtap="clearMenuKeyword">×</view>
    </view>

    <view class="filter-tabs">
      <view
        wx:for="{{archiveFilters}}"
        wx:key="key"
        class="filter-tab {{archiveFilter === item.key ? 'filter-tab-active' : ''}}"
        data-filter="{{item.key}}"
        bindtap="onArchiveFilterTap"
      >
        {{item.label}}
      </view>
    </view>

    <scroll-view wx:if="{{displayMenus.length > 0}}" class="menu-scroll" scroll-y show-scrollbar="{{false}}">
      <view class="menu-list">
        <view wx:for="{{displayMenus}}" wx:key="id" class="menu-item {{item.isArchived ? 'menu-item-archived' : ''}}">
          <view class="menu-copy">
            <view class="status-row">
              <text class="status-pill {{item.isArchived ? 'archived-pill' : 'active-pill'}}">{{item.isArchived ? '已下架' : '上架中'}}</text>
            </view>
            <text class="menu-name">{{item.name}}</text>
            <text class="menu-desc">{{item.desc}}</text>
            <text class="menu-meta">ID {{item.id}} · {{item.likeCount}} 人喜欢</text>
          </view>
          <view class="menu-actions">
            <button class="edit-btn" data-id="{{item.id}}" bindtap="editMenu">编辑</button>
            <button
              class="archive-btn"
              data-id="{{item.id}}"
              data-name="{{item.name}}"
              data-archived="{{item.isArchived ? 1 : 0}}"
              bindtap="archiveMenu"
            >
              {{item.isArchived ? '上架' : '下架'}}
            </button>
            <button
              class="delete-btn"
              data-id="{{item.id}}"
              data-name="{{item.name}}"
              bindtap="deleteMenu"
            >
              删除
            </button>
          </view>
        </view>
      </view>
    </scroll-view>

    <view wx:else class="empty-card">
      <text class="empty-title">{{loading ? '正在加载菜单' : (menuKeyword ? '没有找到菜单' : '暂无菜单')}}</text>
      <text class="empty-desc">{{menuKeyword ? '换一个关键词再试。' : '点击新增菜品后会出现在这里。'}}</text>
    </view>
  </view>

  <view wx:if="{{adminSection === 'menu' && showEditor && formReady}}" class="panel">
    <view class="panel-header">
      <text class="panel-title">{{editingMenuId ? '编辑素食' : '新增素食'}}</text>
      <button class="ghost-btn" bindtap="resetForm">取消</button>
    </view>

    <input
      class="field"
      placeholder="菜品名称"
      placeholder-class="placeholder"
      value="{{form.name}}"
      data-field="name"
      bindinput="updateField"
    />
    <textarea
      class="textarea"
      placeholder="菜品介绍"
      placeholder-class="placeholder"
      value="{{form.desc}}"
      data-field="desc"
      bindinput="updateField"
    />
    <view class="image-uploader">
      <image wx:if="{{form.imageUrl}}" class="image-preview" src="{{form.imageUrl}}" mode="aspectFill"></image>
      <view wx:else class="image-placeholder">
        <text>菜品图片</text>
      </view>
      <view class="image-actions">
        <text class="image-url">{{form.imageUrl ? '图片已上传' : '从相册选择或拍照上传'}}</text>
        <button class="ghost-btn image-btn" loading="{{uploadingImage}}" bindtap="chooseMenuImage">选择图片</button>
      </view>
    </view>
    <view class="switch-row">
      <view>
        <text class="switch-title">下架菜品</text>
        <text class="switch-desc">下架后用户端不显示</text>
      </view>
      <switch checked="{{form.isArchived}}" color="#ad693e" bindchange="onMenuArchivedChange" />
    </view>
    <text class="field-label">主要食材（可选）</text>
    <input
      class="field"
      placeholder="例如：豆腐、紫菜、番茄，最多展示三项"
      placeholder-class="placeholder"
      value="{{form.ingredients}}"
      data-field="ingredients"
      bindinput="updateField"
    />
    <text class="field-label">营养价值表</text>
    <view class="metric-list">
      <view class="metric-header">
        <text>名称</text>
        <text>数量</text>
        <text>单位</text>
      </view>
      <view class="metric-row" wx:for="{{form.nutrition}}" wx:key="id">
        <input
          class="metric-input name-input"
          placeholder="蛋白质"
          placeholder-class="placeholder"
          value="{{item.name}}"
          data-type="nutrition"
          data-index="{{index}}"
          data-field="name"
          bindinput="updateMetricField"
        />
        <input
          class="metric-input quantity-input"
          type="digit"
          placeholder="10"
          placeholder-class="placeholder"
          value="{{item.quantity}}"
          data-type="nutrition"
          data-index="{{index}}"
          data-field="quantity"
          bindinput="updateMetricField"
        />
        <picker
          range="{{unitOptions}}"
          value="{{item.unitIndex}}"
          data-type="nutrition"
          data-index="{{index}}"
          bindchange="updateMetricUnit"
        >
          <view class="metric-picker {{item.unit ? '' : 'metric-picker-empty'}}">{{item.unit || '单位'}}</view>
        </picker>
        <button
          wx:if="{{form.nutrition.length > 1}}"
          class="row-remove-btn"
          data-type="nutrition"
          data-index="{{index}}"
          bindtap="removeMetricRow"
        >
          删除
        </button>
      </view>
      <button wx:if="{{form.nutrition.length < 3}}" class="row-add-btn" data-type="nutrition" bindtap="addMetricRow">添加营养</button>
    </view>

    <button class="primary-btn" loading="{{saving}}" bindtap="submitMenu">{{editingMenuId ? '更新菜品' : '保存菜品'}}</button>
  </view>

  <view wx:if="{{adminSection === 'combo' && !showComboEditor}}" class="panel">
    <view class="panel-header menu-panel-header">
      <text class="panel-title">今日推荐</text>
      <view class="panel-actions">
        <button class="ghost-btn" loading="{{loading}}" bindtap="loadCombos">刷新</button>
        <button class="compact-primary-btn" bindtap="startCreateCombo">新增推荐</button>
      </view>
    </view>

    <view class="admin-search">
      <text class="admin-search-icon">⌕</text>
      <input
        class="admin-search-input"
        placeholder="搜索推荐、说明或菜品"
        placeholder-class="placeholder"
        value="{{comboKeyword}}"
        bindinput="onComboKeywordInput"
      />
      <view wx:if="{{comboKeyword}}" class="admin-clear-btn" bindtap="clearComboKeyword">×</view>
    </view>

    <scroll-view wx:if="{{displayCombos.length > 0}}" class="menu-scroll" scroll-y show-scrollbar="{{false}}">
      <view class="menu-list">
        <view wx:for="{{displayCombos}}" wx:key="id" class="combo-admin-item">
          <view class="menu-copy">
            <view class="status-row">
              <text wx:if="{{item.isActive}}" class="status-pill recommend-pill">首页展示</text>
              <text class="status-pill active-pill">{{item.items.length}} / 4</text>
            </view>
            <text class="menu-name">{{item.title}}</text>
            <text class="menu-desc">{{item.description}}</text>
            <text class="menu-meta">ID {{item.id}}</text>
            <view class="combo-admin-tags">
              <text class="status-pill archived-pill" wx:for="{{item.items}}" wx:key="id">{{item.slotLabel}}：{{item.name}}</text>
            </view>
          </view>
          <view class="menu-actions">
            <button class="edit-btn" data-id="{{item.id}}" bindtap="editCombo">编辑</button>
            <button class="minor-btn" data-id="{{item.id}}" data-active="{{item.isActive ? 1 : 0}}" bindtap="toggleComboActive">{{item.isActive ? '取消' : '启用'}}</button>
            <button class="delete-btn" data-id="{{item.id}}" data-title="{{item.title}}" bindtap="deleteCombo">删除</button>
          </view>
        </view>
      </view>
    </scroll-view>

    <view wx:else class="empty-card">
      <text class="empty-title">{{loading ? '正在加载推荐' : (comboKeyword ? '没有找到推荐' : '暂无推荐')}}</text>
      <text class="empty-desc">{{comboKeyword ? '换一个关键词再试。' : '点击新增推荐后会出现在首页。'}}</text>
    </view>
  </view>

  <view wx:if="{{adminSection === 'combo' && showComboEditor}}" class="panel">
    <view class="panel-header">
      <text class="panel-title">{{editingComboId ? '编辑推荐' : '新增推荐'}}</text>
      <button class="ghost-btn" bindtap="resetComboForm">取消</button>
    </view>
    <input
      class="field"
      placeholder="推荐名称"
      placeholder-class="placeholder"
      value="{{comboForm.title}}"
      data-field="title"
      bindinput="updateComboField"
    />
    <textarea
      class="textarea"
      placeholder="推荐说明"
      placeholder-class="placeholder"
      value="{{comboForm.description}}"
      data-field="description"
      bindinput="updateComboField"
    />
    <view class="switch-row">
      <view>
        <text class="switch-title">首页展示</text>
        <text class="switch-desc">同一时间仅一个今日推荐生效</text>
      </view>
      <switch checked="{{comboForm.isActive}}" color="#ad693e" bindchange="onComboActiveChange" />
    </view>
    <text class="field-label">选择菜品（按顺序选择 4 道）</text>
    <text class="field-help">第 1 道前菜/小菜，第 2 道主食，第 3 道热食，第 4 道甜品/饮品。</text>
    <view class="combo-menu-picker">
      <view
        wx:for="{{comboMenuOptions}}"
        wx:key="id"
        class="combo-menu-option {{item.selected ? 'combo-menu-option-selected' : ''}}"
        data-id="{{item.id}}"
        bindtap="toggleComboMenu"
      >
        <text wx:if="{{item.selected}}" class="combo-menu-option-slot">{{item.selectedIndex + 1}} · {{item.slotLabel}}</text>
        <text class="combo-menu-option-name">{{item.name}}</text>
        <text class="combo-menu-option-desc">{{item.desc}}</text>
      </view>
    </view>
    <button class="primary-btn" loading="{{saving}}" bindtap="submitCombo">{{editingComboId ? '更新推荐' : '保存推荐'}}</button>
  </view>

  <view wx:if="{{adminSection === 'activity' && !showActivityEditor}}" class="panel">
    <view class="panel-header menu-panel-header">
      <text class="panel-title">活动列表</text>
      <view class="panel-actions">
        <button class="ghost-btn" loading="{{loading}}" bindtap="loadActivities">刷新</button>
        <button class="compact-primary-btn" bindtap="startCreateActivity">新增活动</button>
      </view>
    </view>

    <view class="admin-search">
      <text class="admin-search-icon">⌕</text>
      <input
        class="admin-search-input"
        placeholder="搜索活动、地点或 ID"
        placeholder-class="placeholder"
        value="{{activityKeyword}}"
        bindinput="onActivityKeywordInput"
      />
      <view wx:if="{{activityKeyword}}" class="admin-clear-btn" bindtap="clearActivityKeyword">×</view>
    </view>

    <scroll-view wx:if="{{displayActivities.length > 0}}" class="menu-scroll" scroll-y show-scrollbar="{{false}}">
      <view class="menu-list">
        <view wx:for="{{displayActivities}}" wx:key="id" class="activity-item">
          <view class="menu-copy">
            <view class="status-row">
              <text wx:if="{{item.isTop}}" class="status-pill recommend-pill">置顶</text>
              <text class="status-pill active-pill">展示中</text>
            </view>
            <text class="menu-name">{{item.title}}</text>
            <text class="menu-desc">{{item.eventTime}} · {{item.place}}</text>
            <text class="menu-meta">ID {{item.id}} · {{item.content}}</text>
          </view>
          <view class="menu-actions">
            <button class="edit-btn" data-id="{{item.id}}" bindtap="editActivity">编辑</button>
            <button class="minor-btn" data-id="{{item.id}}" data-top="{{item.isTop ? 1 : 0}}" bindtap="toggleActivityTop">{{item.isTop ? '取消置顶' : '置顶'}}</button>
            <button class="delete-btn" data-id="{{item.id}}" data-title="{{item.title}}" bindtap="deleteActivity">删除</button>
          </view>
        </view>
      </view>
    </scroll-view>

    <view wx:else class="empty-card">
      <text class="empty-title">{{loading ? '正在加载活动' : (activityKeyword ? '没有找到活动' : '暂无活动')}}</text>
      <text class="empty-desc">{{activityKeyword ? '换一个关键词再试。' : '点击新增活动后会出现在这里。'}}</text>
    </view>
  </view>

  <view wx:if="{{adminSection === 'activity' && showActivityEditor}}" class="panel">
    <view class="panel-header">
      <text class="panel-title">{{editingActivityId ? '编辑活动' : '新增活动'}}</text>
      <button class="ghost-btn" bindtap="resetActivityForm">取消</button>
    </view>
    <input
      class="field"
      placeholder="活动标题"
      placeholder-class="placeholder"
      value="{{activityForm.title}}"
      data-field="title"
      bindinput="updateActivityField"
    />
    <input
      class="field"
      placeholder="活动时间，例如 周六 10:30"
      placeholder-class="placeholder"
      value="{{activityForm.eventTime}}"
      data-field="eventTime"
      bindinput="updateActivityField"
    />
    <input
      class="field"
      placeholder="活动地点"
      placeholder-class="placeholder"
      value="{{activityForm.place}}"
      data-field="place"
      bindinput="updateActivityField"
    />
    <textarea
      class="textarea"
      placeholder="活动介绍"
      placeholder-class="placeholder"
      value="{{activityForm.content}}"
      data-field="content"
      bindinput="updateActivityField"
    />
    <view class="switch-row">
      <view>
        <text class="switch-title">首页置顶</text>
        <text class="switch-desc">置顶活动会优先显示在首页近期活动</text>
      </view>
      <switch checked="{{activityForm.isTop}}" color="#ad693e" bindchange="onActivityTopChange" />
    </view>
    <button class="primary-btn" loading="{{saving}}" bindtap="submitActivity">{{editingActivityId ? '更新活动' : '保存活动'}}</button>
  </view>

  <view wx:if="{{adminSection === 'comment'}}" class="panel">
    <view class="panel-header menu-panel-header">
      <text class="panel-title">评论列表</text>
      <view class="panel-actions">
        <button class="ghost-btn" loading="{{loading}}" bindtap="loadComments">刷新</button>
      </view>
    </view>

    <view class="admin-search">
      <text class="admin-search-icon">⌕</text>
      <input
        class="admin-search-input"
        placeholder="搜索评论、用户、菜品或 ID"
        placeholder-class="placeholder"
        value="{{commentKeyword}}"
        bindinput="onCommentKeywordInput"
      />
      <view wx:if="{{commentKeyword}}" class="admin-clear-btn" bindtap="clearCommentKeyword">×</view>
    </view>

    <scroll-view wx:if="{{displayComments.length > 0}}" class="menu-scroll" scroll-y show-scrollbar="{{false}}">
      <view class="menu-list">
        <view wx:for="{{displayComments}}" wx:key="id" class="comment-item">
          <view class="menu-copy">
            <view class="status-row">
              <text class="status-pill active-pill">评论</text>
              <text class="status-pill archived-pill">ID {{item.id}}</text>
            </view>
            <text class="menu-name">{{item.menuName}}</text>
            <text class="comment-text">{{item.comment}}</text>
            <text class="menu-meta">{{item.userName}} · {{item.date}}</text>
          </view>
          <view class="menu-actions">
            <button
              class="delete-btn"
              data-id="{{item.id}}"
              data-menu-name="{{item.menuName}}"
              bindtap="deleteComment"
            >
              删除
            </button>
          </view>
        </view>
      </view>
    </scroll-view>

    <view wx:else class="empty-card">
      <text class="empty-title">{{loading ? '正在加载评论' : (commentKeyword ? '没有找到评论' : '暂无评论')}}</text>
      <text class="empty-desc">{{commentKeyword ? '换一个关键词再试。' : '用户评论后会出现在这里。'}}</text>
    </view>
  </view>

  <view wx:if="{{adminSection === 'suggestion'}}" class="panel">
    <view class="panel-header menu-panel-header">
      <text class="panel-title">建议列表</text>
      <view class="panel-actions">
        <button class="ghost-btn" loading="{{loading}}" bindtap="loadSuggestions">刷新</button>
      </view>
    </view>

    <view class="admin-search">
      <text class="admin-search-icon">⌕</text>
      <input
        class="admin-search-input"
        placeholder="搜索建议、用户或联系方式"
        placeholder-class="placeholder"
        value="{{suggestionKeyword}}"
        bindinput="onSuggestionKeywordInput"
      />
      <view wx:if="{{suggestionKeyword}}" class="admin-clear-btn" bindtap="clearSuggestionKeyword">×</view>
    </view>

    <view class="filter-tabs">
      <view
        wx:for="{{suggestionFilters}}"
        wx:key="key"
        class="filter-tab {{suggestionFilter === item.key ? 'filter-tab-active' : ''}}"
        data-filter="{{item.key}}"
        bindtap="onSuggestionFilterTap"
      >
        {{item.label}}
      </view>
    </view>

    <scroll-view wx:if="{{displaySuggestions.length > 0}}" class="menu-scroll" scroll-y show-scrollbar="{{false}}">
      <view class="menu-list">
        <view wx:for="{{displaySuggestions}}" wx:key="id" class="suggestion-item">
          <view class="menu-copy">
            <view class="status-row">
              <text class="status-pill {{item.handled ? 'active-pill' : 'recommend-pill'}}">{{item.handled ? '已处理' : '未处理'}}</text>
              <text class="status-pill archived-pill">ID {{item.id}}</text>
            </view>
            <text class="suggestion-content">{{item.content}}</text>
            <text class="menu-meta">{{item.userName}} · {{item.date}}</text>
            <text class="menu-meta">联系方式：{{item.contact}}</text>
          </view>
          <view class="menu-actions">
            <button
              class="minor-btn"
              data-id="{{item.id}}"
              data-handled="{{item.handled ? 1 : 0}}"
              bindtap="toggleSuggestionStatus"
            >
              {{item.handled ? '未处理' : '已处理'}}
            </button>
          </view>
        </view>
      </view>
    </scroll-view>

    <view wx:else class="empty-card">
      <text class="empty-title">{{loading ? '正在加载建议' : (suggestionKeyword ? '没有找到建议' : '暂无建议')}}</text>
      <text class="empty-desc">{{suggestionKeyword ? '换一个关键词再试。' : '用户提交建议后会出现在这里。'}}</text>
    </view>
  </view>
  <button class="logout-btn" bindtap="logoutAdmin">退出管理</button>
  </block>
</view>
