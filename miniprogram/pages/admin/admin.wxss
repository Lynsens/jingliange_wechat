.admin-page {
  min-height: 100vh;
  background: #fbecdf;
  color: #17120f;
  padding: 28rpx;
}

.admin-hero,
.panel {
  border: 1rpx solid rgba(23, 18, 15, 0.1);
  border-radius: 14rpx;
  background: #fffaf6;
}

.admin-hero {
  padding: 32rpx 30rpx;
}

.admin-kicker,
.admin-desc,
.panel-title,
.menu-name,
.menu-desc,
.menu-meta,
.empty-title,
.empty-desc,
.login-note {
  display: block;
}

.admin-kicker {
  color: #7c4a27;
  font-family: "STKaiti", "Kaiti SC", "KaiTi", "Songti SC", serif;
  font-size: 30rpx;
  line-height: 40rpx;
}

.admin-desc {
  margin-top: 12rpx;
  color: #6f5545;
  font-size: 25rpx;
  line-height: 38rpx;
}

.panel {
  margin-top: 22rpx;
  padding: 26rpx;
}

.login-panel {
  padding-top: 30rpx;
}

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.panel-title {
  color: #17120f;
  font-size: 32rpx;
  font-weight: 800;
}

.ghost-btn {
  width: 112rpx;
  height: 58rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(23, 18, 15, 0.12);
  background: #fbecdf;
  color: #7c4a27;
  font-size: 24rpx;
  line-height: 58rpx;
  padding: 0;
}

.field,
.textarea {
  width: 100%;
  box-sizing: border-box;
  border-radius: 12rpx;
  background: #fff7f0;
  color: #17120f;
  font-size: 27rpx;
  padding: 0 20rpx;
}

.field {
  height: 82rpx;
  margin-top: 16rpx;
}

.field-label {
  display: block;
  margin-top: 18rpx;
  color: #7b6253;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 34rpx;
}

.textarea {
  height: 152rpx;
  margin-top: 10rpx;
  padding-top: 20rpx;
  line-height: 38rpx;
}

.textarea.small {
  height: 128rpx;
}

.image-uploader {
  display: flex;
  align-items: center;
  gap: 18rpx;
  box-sizing: border-box;
  min-height: 132rpx;
  margin-top: 16rpx;
  border-radius: 12rpx;
  background: #fff7f0;
  padding: 18rpx;
}

.image-preview,
.image-placeholder {
  flex: 0 0 auto;
  width: 112rpx;
  height: 112rpx;
  border-radius: 12rpx;
  background: #ead1bd;
}

.image-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7c4a27;
  font-size: 23rpx;
}

.image-actions {
  min-width: 0;
  flex: 1;
}

.image-url {
  display: block;
  color: #7b6253;
  font-size: 24rpx;
  line-height: 34rpx;
}

.image-btn {
  width: 142rpx;
  margin: 14rpx 0 0;
}

.placeholder {
  color: #a4836e;
}

.primary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 82rpx;
  box-sizing: border-box;
  border-radius: 12rpx;
  background: #ad693e;
  color: #fff;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1;
  margin-top: 18rpx;
  padding: 0;
}

.login-note {
  margin-top: 18rpx;
  color: #7b6253;
  font-size: 23rpx;
  line-height: 34rpx;
}

.menu-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.menu-item {
  display: flex;
  gap: 18rpx;
  align-items: center;
  border-radius: 12rpx;
  background: #fff7f0;
  padding: 20rpx;
}

.menu-copy {
  min-width: 0;
  flex: 1;
}

.menu-name {
  color: #17120f;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 38rpx;
}

.menu-desc {
  margin-top: 6rpx;
  color: #6f5545;
  font-size: 24rpx;
  line-height: 34rpx;
}

.menu-meta {
  margin-top: 8rpx;
  color: #a4836e;
  font-size: 22rpx;
}

.delete-btn {
  flex: 0 0 auto;
  width: 96rpx;
  height: 60rpx;
  border-radius: 999rpx;
  background: #17120f;
  color: #fff;
  font-size: 24rpx;
  line-height: 60rpx;
  padding: 0;
}

.logout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 82rpx;
  box-sizing: border-box;
  margin-top: 22rpx;
  border-radius: 12rpx;
  background: #17120f;
  color: #fff;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1;
  padding: 0;
}

.empty-card {
  border-radius: 12rpx;
  background: #fff7f0;
  padding: 36rpx 28rpx;
  text-align: center;
}

.empty-title {
  color: #17120f;
  font-size: 30rpx;
  font-weight: 700;
}

.empty-desc {
  margin-top: 10rpx;
  color: #7b6253;
  font-size: 25rpx;
  line-height: 36rpx;
}

button {
  border: 0;
}

button::after {
  border: 0;
}
