.admin-page {
  min-height: 100vh;
  background: #fbecdf;
  color: #17120f;
  padding: 52rpx 28rpx 28rpx;
}

.admin-hero,
.panel {
  border: 1rpx solid rgba(23, 18, 15, 0.1);
  border-radius: 14rpx;
  background: #fffaf6;
}

.admin-hero {
  padding: 32rpx 30rpx;
}

.admin-kicker,
.admin-desc,
.panel-title,
.menu-name,
.menu-desc,
.menu-meta,
.empty-title,
.empty-desc,
.login-note,
.switch-title,
.switch-desc {
  display: block;
}

.admin-kicker {
  color: #7c4a27;
  font-family: "STKaiti", "Kaiti SC", "KaiTi", "Songti SC", serif;
  font-size: 30rpx;
  line-height: 40rpx;
}

.admin-desc {
  margin-top: 12rpx;
  color: #6f5545;
  font-size: 25rpx;
  line-height: 38rpx;
}

.panel {
  margin-top: 22rpx;
  padding: 26rpx;
}

.login-panel {
  padding-top: 30rpx;
}

.admin-tabs,
.filter-tabs {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.admin-tabs {
  margin-top: 22rpx;
  flex-wrap: wrap;
}

.admin-tab,
.filter-tab {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border: 1rpx solid rgba(23, 18, 15, 0.1);
  border-radius: 999rpx;
  background: #fffaf6;
  color: #6f5545;
  margin: 0;
  padding: 0 22rpx;
}

.admin-tab {
  flex: 1 1 220rpx;
  height: 68rpx;
  font-size: 25rpx;
  font-weight: 700;
}

.admin-tab-active,
.filter-tab-active {
  border-color: #ad693e;
  background: #ad693e;
  color: #fff;
}

.filter-tabs {
  margin-bottom: 18rpx;
}

.filter-tab {
  height: 54rpx;
  min-width: 112rpx;
  font-size: 23rpx;
}

.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.menu-panel-header {
  display: block;
}

.panel-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
  margin-top: 14rpx;
}

.panel-title {
  min-width: 0;
  color: #17120f;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 58rpx;
}

.ghost-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 58rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  border: 1rpx solid rgba(23, 18, 15, 0.12);
  background: #fbecdf;
  color: #7c4a27;
  font-size: 24rpx;
  line-height: 1;
  margin: 0;
  padding: 0;
}

.field,
.textarea {
  width: 100%;
  box-sizing: border-box;
  border-radius: 12rpx;
  background: #fff7f0;
  color: #17120f;
  font-size: 27rpx;
  padding: 0 20rpx;
}

.field {
  height: 82rpx;
  margin-top: 16rpx;
}

.field-label {
  display: block;
  margin-top: 18rpx;
  color: #7b6253;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 34rpx;
}

.textarea {
  height: 152rpx;
  margin-top: 10rpx;
  padding-top: 20rpx;
  line-height: 38rpx;
}

.textarea.small {
  height: 128rpx;
}

.metric-list {
  margin-top: 10rpx;
  border-radius: 12rpx;
  background: #fff7f0;
  padding: 16rpx;
}

.metric-header,
.metric-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 132rpx 118rpx;
  gap: 12rpx;
  align-items: center;
}

.metric-header {
  color: #8b6a56;
  font-size: 22rpx;
  line-height: 30rpx;
  padding: 0 4rpx 10rpx;
}

.metric-row + .metric-row {
  margin-top: 18rpx;
}

.metric-input {
  min-width: 0;
  height: 72rpx;
  box-sizing: border-box;
  border-radius: 10rpx;
  background: #fffaf6;
  color: #17120f;
  font-size: 25rpx;
  padding: 0 14rpx;
}

.quantity-input {
  text-align: center;
}

.metric-picker {
  position: relative;
  height: 72rpx;
  box-sizing: border-box;
  border-radius: 10rpx;
  background: #fffaf6;
  color: #17120f;
  font-size: 25rpx;
  line-height: 72rpx;
  text-align: center;
  padding: 0 24rpx 0 10rpx;
}

.metric-picker::after {
  content: "";
  position: absolute;
  top: 31rpx;
  right: 12rpx;
  width: 0;
  height: 0;
  border-left: 7rpx solid transparent;
  border-right: 7rpx solid transparent;
  border-top: 9rpx solid #a4836e;
}

.metric-picker-empty {
  color: #a4836e;
}

.row-remove-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  grid-column: 1 / -1;
  justify-self: end;
  width: 92rpx;
  height: 44rpx;
  margin-top: -2rpx;
  border-radius: 999rpx;
  background: #f8dfca;
  color: #7c4a27;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
  padding: 0;
}

.row-add-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 68rpx;
  box-sizing: border-box;
  margin-top: 14rpx;
  border-radius: 10rpx;
  background: #fbecdf;
  color: #7c4a27;
  font-size: 25rpx;
  font-weight: 700;
  line-height: 1;
  padding: 0;
}

.image-uploader {
  display: flex;
  align-items: center;
  gap: 18rpx;
  box-sizing: border-box;
  min-height: 132rpx;
  margin-top: 16rpx;
  border-radius: 12rpx;
  background: #fff7f0;
  padding: 18rpx;
}

.image-preview,
.image-placeholder {
  flex: 0 0 auto;
  width: 112rpx;
  height: 112rpx;
  border-radius: 12rpx;
  background: #ead1bd;
}

.image-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #7c4a27;
  font-size: 23rpx;
}

.image-actions {
  min-width: 0;
  flex: 1;
}

.image-url {
  display: block;
  color: #7b6253;
  font-size: 24rpx;
  line-height: 34rpx;
}

.image-btn {
  width: 142rpx;
  margin: 14rpx 0 0;
}

.placeholder {
  color: #a4836e;
}

.primary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 82rpx;
  box-sizing: border-box;
  border-radius: 12rpx;
  background: #ad693e;
  color: #fff;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1;
  margin-top: 18rpx;
  padding: 0;
}

.compact-primary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 170rpx;
  height: 58rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  background: #ad693e;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1;
  margin: 0;
  padding: 0;
}

.login-note {
  margin-top: 18rpx;
  color: #7b6253;
  font-size: 23rpx;
  line-height: 34rpx;
}

.admin-search {
  display: flex;
  align-items: center;
  height: 78rpx;
  box-sizing: border-box;
  margin-bottom: 18rpx;
  border-radius: 12rpx;
  background: #fff7f0;
  padding: 0 16rpx;
}

.admin-search-icon {
  flex: 0 0 auto;
  width: 42rpx;
  color: #8b6a56;
  font-size: 30rpx;
  line-height: 78rpx;
}

.admin-search-input {
  min-width: 0;
  flex: 1;
  height: 78rpx;
  color: #17120f;
  font-size: 26rpx;
}

.admin-clear-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 46rpx;
  width: 46rpx;
  height: 46rpx;
  min-width: 46rpx;
  max-width: 46rpx;
  box-sizing: border-box;
  margin: 0;
  border-radius: 50%;
  background: #f8dfca;
  color: #7c4a27;
  font-size: 30rpx;
  line-height: 1;
  padding: 0;
}

.menu-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.menu-scroll {
  height: 760rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.menu-item {
  display: flex;
  gap: 18rpx;
  align-items: center;
  border-radius: 12rpx;
  background: #fff7f0;
  padding: 20rpx;
}

.activity-item,
.comment-item,
.suggestion-item,
.combo-admin-item {
  display: flex;
  gap: 18rpx;
  align-items: center;
  border-radius: 12rpx;
  background: #fff7f0;
  padding: 20rpx;
}

.menu-item-archived {
  background: #f8eee7;
}

.menu-copy {
  min-width: 0;
  flex: 1;
}

.menu-name {
  color: #17120f;
  font-size: 29rpx;
  font-weight: 800;
  line-height: 38rpx;
}

.menu-desc {
  margin-top: 6rpx;
  color: #6f5545;
  font-size: 24rpx;
  line-height: 34rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.menu-meta {
  margin-top: 8rpx;
  color: #a4836e;
  font-size: 22rpx;
  line-height: 30rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}

.comment-text {
  display: block;
  margin-top: 8rpx;
  color: #6f5545;
  font-size: 25rpx;
  line-height: 36rpx;
  word-break: break-word;
}

.suggestion-content {
  display: block;
  color: #17120f;
  font-size: 26rpx;
  line-height: 38rpx;
  word-break: break-word;
}

.combo-admin-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 10rpx;
}

.combo-menu-picker {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 14rpx;
}

.combo-menu-option {
  border: 1rpx solid rgba(23, 18, 15, 0.08);
  border-radius: 12rpx;
  background: #fff7f0;
  padding: 18rpx 20rpx;
}

.combo-menu-option-selected {
  border-color: #ad693e;
  background: #f8dfca;
}

.combo-menu-option-name,
.combo-menu-option-desc {
  display: block;
}

.combo-menu-option-name {
  color: #17120f;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 34rpx;
}

.combo-menu-option-desc {
  margin-top: 4rpx;
  color: #6f5545;
  font-size: 22rpx;
  line-height: 30rpx;
}

.status-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.status-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 34rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1;
  padding: 0 12rpx;
}

.recommend-pill {
  background: #ad693e;
  color: #fff;
}

.active-pill {
  background: #e6f0de;
  color: #51643b;
}

.archived-pill {
  background: #ece1d9;
  color: #7b6253;
}

.menu-actions {
  flex: 0 0 auto;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.edit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 104rpx;
  height: 56rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1;
  margin: 0;
  padding: 0;
}

.edit-btn {
  background: #f8dfca;
  color: #7c4a27;
}

.minor-btn,
.archive-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 104rpx;
  height: 48rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  font-size: 21rpx;
  font-weight: 700;
  line-height: 1;
  margin: 0;
  padding: 0;
}

.minor-btn {
  background: #fff0df;
  color: #8a5839;
}

.archive-btn {
  background: #ede2d8;
  color: #6f5545;
}

.delete-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 48rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  background: #f3d5cc;
  color: #9a4638;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
  margin: 0;
  padding: 0;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  box-sizing: border-box;
  margin-top: 16rpx;
  border-radius: 12rpx;
  background: #fff7f0;
  padding: 18rpx 20rpx;
}

.switch-title {
  color: #17120f;
  font-size: 26rpx;
  font-weight: 800;
  line-height: 34rpx;
}

.switch-desc {
  margin-top: 4rpx;
  color: #8b6a56;
  font-size: 22rpx;
  line-height: 30rpx;
}

.logout-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 82rpx;
  box-sizing: border-box;
  margin-top: 22rpx;
  border-radius: 12rpx;
  background: #17120f;
  color: #fff;
  font-size: 29rpx;
  font-weight: 700;
  line-height: 1;
  padding: 0;
}

.empty-card {
  border-radius: 12rpx;
  background: #fff7f0;
  padding: 36rpx 28rpx;
  text-align: center;
}

.empty-title {
  color: #17120f;
  font-size: 30rpx;
  font-weight: 700;
}

.empty-desc {
  margin-top: 10rpx;
  color: #7b6253;
  font-size: 25rpx;
  line-height: 36rpx;
}

button {
  border: 0;
}

button::after {
  border: 0;
}
